<section class="rounded-lg border border-line bg-white p-6 shadow-sm dark:border-white/10 dark:bg-white/5">
  <p class="text-sm font-bold uppercase tracking-wider text-flame"><%= title %></p>
  <h2 class="mt-2 font-display text-3xl font-extrabold"><%= title %></h2>
  <p class="mt-3 max-w-2xl text-sm leading-6 text-ink/70 dark:text-white/65"><%= description %></p>
  <div class="mt-8 grid gap-4 md:grid-cols-3">
    <div class="rounded-lg border border-line bg-paper p-5 dark:border-white/10 dark:bg-white/5">
      <p class="text-sm font-bold">Status</p>
      <p class="mt-2 text-sm text-ink/70 dark:text-white/60">Module shell is ready for CRUD expansion.</p>
    </div>
    <div class="rounded-lg border border-line bg-paper p-5 dark:border-white/10 dark:bg-white/5">
      <p class="text-sm font-bold">Security</p>
      <p class="mt-2 text-sm text-ink/70 dark:text-white/60">Protected by session authentication, role checks, and CSRF.</p>
    </div>
    <div class="rounded-lg border border-line bg-paper p-5 dark:border-white/10 dark:bg-white/5">
      <p class="text-sm font-bold">Scalable</p>
      <p class="mt-2 text-sm text-ink/70 dark:text-white/60">Designed to grow inside the existing MVC module pattern.</p>
    </div>
  </div>
</section>
