<header class="sticky top-0 z-40 border-b border-line bg-paper/90 backdrop-blur">
  <a href="#main-content" class="focus-ring sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-4 focus:py-2">
    Skip to content
  </a>
  <div class="container-page">
    <div class="flex h-16 items-center justify-between gap-4">
      <a href="/" class="focus-ring rounded-md font-display text-lg font-extrabold tracking-normal text-ink">
        Kabir Mahmud
      </a>

      <%- include("./navbar") %>

      <button
        type="button"
        data-menu-button
        class="focus-ring inline-flex h-10 w-10 items-center justify-center rounded-md border border-line bg-white md:hidden"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="h-0.5 w-5 bg-ink before:block before:h-0.5 before:w-5 before:-translate-y-1.5 before:bg-ink after:block after:h-0.5 after:w-5 after:translate-y-1 after:bg-ink"></span>
      </button>
    </div>

    <div data-mobile-menu class="hidden border-t border-line py-3 md:hidden">
      <nav class="grid gap-1" aria-label="Mobile navigation">
        <a class="nav-link <%= currentPath === '/' ? 'nav-link-active' : '' %>" href="/">Home</a>
        <a class="nav-link <%= currentPath === '/about' ? 'nav-link-active' : '' %>" href="/about">About</a>
        <a class="nav-link <%= currentPath.startsWith('/blog') ? 'nav-link-active' : '' %>" href="/blog">Blog</a>
        <a class="nav-link <%= currentPath.startsWith('/projects') ? 'nav-link-active' : '' %>" href="/projects">Projects</a>
        <a class="nav-link <%= currentPath.startsWith('/tools') ? 'nav-link-active' : '' %>" href="/tools">Tools</a>
        <a class="nav-link <%= currentPath === '/contact' ? 'nav-link-active' : '' %>" href="/contact">Contact</a>
      </nav>
    </div>
  </div>
</header>
