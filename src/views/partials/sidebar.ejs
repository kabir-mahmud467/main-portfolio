<aside
  data-admin-sidebar
  class="fixed inset-y-0 left-0 z-40 w-72 -translate-x-full border-r border-white/10 bg-ink p-5 text-white transition-transform lg:static lg:translate-x-0"
>
  <a href="/admin" class="focus-ring block rounded-md font-display text-xl font-extrabold">
    Kabir Admin
  </a>
  <p class="mt-2 text-sm text-white/60">Content, tools, projects, and settings.</p>

  <nav class="mt-8 grid gap-2" aria-label="Admin navigation">
    <a class="rounded-md <%= currentPath === '/admin' ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin">Dashboard</a>
    <a class="rounded-md <%= currentPath.startsWith('/admin/posts') ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin/posts">Posts</a>
    <a class="rounded-md <%= currentPath.startsWith('/admin/projects') ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin/projects">Projects</a>
    <a class="rounded-md <%= currentPath.startsWith('/admin/tools') ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin/tools">Tools</a>
    <a class="rounded-md <%= currentPath.startsWith('/admin/categories') ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin/categories">Categories</a>
    <a class="rounded-md <%= currentPath.startsWith('/admin/media') ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin/media">Media Library</a>
    <a class="rounded-md <%= currentPath.startsWith('/admin/analytics') ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin/analytics">Analytics</a>
    <a class="rounded-md <%= currentPath.startsWith('/admin/settings') ? 'bg-white/10 text-white' : 'text-white/75' %> px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white" href="/admin/settings">Settings</a>
  </nav>
  <form action="/admin/logout" method="post" class="mt-8">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button class="w-full rounded-md border border-white/10 px-3 py-2 text-left text-sm font-semibold text-white/75 hover:bg-white/10 hover:text-white" type="submit">Logout</button>
  </form>
</aside>
