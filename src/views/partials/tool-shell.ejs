<section class="border-b border-line bg-white py-10">
  <div class="container-page">
    <nav class="flex flex-wrap gap-2 text-sm font-semibold text-ink/60" aria-label="Breadcrumb">
      <% tool.breadcrumb.forEach((item, index) => { %>
        <% if (index) { %><span>/</span><% } %>
        <a class="hover:text-ink" href="<%= item.href %>"><%= item.label %></a>
      <% }) %>
    </nav>
    <p class="mt-8 text-sm font-bold uppercase tracking-wider text-flame"><%= tool.category %></p>
    <h1 class="mt-3 font-display text-4xl font-extrabold"><%= tool.name %></h1>
    <p class="mt-4 max-w-2xl text-lg leading-8 text-ink/70"><%= tool.description %></p>
  </div>
</section>
<script type="application/ld+json" nonce="<%= cspNonce %>"><%- schemaJson %></script>
