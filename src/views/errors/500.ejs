<section class="grid min-h-[calc(100vh-4rem)] place-items-center bg-paper py-16">
  <div class="container-page text-center">
    <p class="text-sm font-bold uppercase tracking-wider text-flame"><%= statusCode || 500 %></p>
    <h1 class="mt-4 font-display text-4xl font-extrabold sm:text-5xl">Something went wrong</h1>
    <p class="mx-auto mt-4 max-w-xl text-base leading-7 text-ink/70">
      The server could not complete this request. Please try again later.
    </p>
    <% if (stack) { %>
      <pre class="mx-auto mt-8 max-h-80 overflow-auto rounded-lg border border-line bg-white p-4 text-left text-xs text-ink/70"><%= stack %></pre>
    <% } %>
    <div class="mt-8 flex justify-center gap-3">
      <a class="btn-primary" href="/">Go Home</a>
      <a class="btn-secondary" href="/contact">Contact</a>
    </div>
  </div>
</section>
