<article class="bg-white py-14">
  <div class="container-page max-w-4xl">
    <%- include("../../partials/breadcrumbs") %>
    <h1 class="mt-4 font-display text-4xl font-extrabold leading-tight sm:text-5xl"><%= post.title %></h1>
    <p class="mt-5 text-lg leading-8 text-ink/70"><%= post.excerpt %></p>
    <div class="mt-5 flex flex-wrap gap-3 text-sm font-bold text-ink/55">
      <span><%= post.readingTime %> min read</span>
      <% (post.categories || []).forEach((category) => { %><span><%= category %></span><% }) %>
      <% (post.tags || []).forEach((tag) => { %><span>#<%= tag %></span><% }) %>
    </div>
    <% if (post.coverImage) { %>
      <img class="mt-8 aspect-[16/9] w-full rounded-lg border border-line object-cover" src="<%= post.coverImage %>" alt="" fetchpriority="high" decoding="async">
    <% } %>
    <div class="prose prose-neutral mt-10 max-w-none prose-headings:font-display prose-pre:bg-ink">
      <%- post.html %>
    </div>
  </div>
</article>

<% if (relatedPosts.length) { %>
  <section class="border-t border-line bg-paper py-14">
    <div class="container-page">
      <h2 class="font-display text-3xl font-extrabold">Related posts</h2>
      <div class="mt-6 grid gap-5 md:grid-cols-3">
        <% relatedPosts.forEach((item) => { %>
          <article class="rounded-lg border border-line bg-white p-5">
            <h3 class="font-bold"><a href="/blog/<%= item.slug %>"><%= item.title %></a></h3>
            <p class="mt-2 text-sm leading-6 text-ink/70"><%= item.excerpt %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>
