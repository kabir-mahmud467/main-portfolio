<section class="border-b border-line bg-white py-14">
  <div class="container-page">
    <p class="text-sm font-bold uppercase tracking-wider text-flame">Tech Blog</p>
    <h1 class="mt-3 font-display text-4xl font-extrabold">Engineering notes and case studies</h1>
    <form action="/blog" method="get" class="mt-8 flex max-w-xl gap-2">
      <input class="focus-ring min-h-11 min-w-0 flex-1 rounded-md border border-line px-3" name="search" value="<%= search %>" placeholder="Search posts">
      <button class="btn-primary" type="submit">Search</button>
    </form>
  </div>
</section>

<section class="bg-paper py-14">
  <div class="container-page">
    <% if (!posts.length) { %>
      <div class="rounded-lg border border-line bg-white p-8 text-center">
        <h2 class="font-display text-2xl font-extrabold">No posts yet</h2>
        <p class="mt-2 text-ink/70">Published writing will appear here.</p>
      </div>
    <% } %>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      <% posts.forEach((post) => { %>
        <article class="rounded-lg border border-line bg-white p-5 shadow-sm">
          <% if (post.featured) { %><span class="rounded-md bg-flame/10 px-2 py-1 text-xs font-bold text-flame">Featured</span><% } %>
          <h2 class="mt-3 text-xl font-extrabold"><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2>
          <p class="mt-3 text-sm leading-6 text-ink/70"><%= post.excerpt %></p>
          <div class="mt-4 flex flex-wrap gap-2 text-xs font-bold text-ink/55">
            <span><%= post.readingTime %> min read</span>
            <% (post.tags || []).slice(0, 3).forEach((tag) => { %><span>#<%= tag %></span><% }) %>
          </div>
        </article>
      <% }) %>
    </div>
    <% if (totalPages > 1) { %>
      <nav class="mt-10 flex justify-center gap-2" aria-label="Pagination">
        <% for (let i = 1; i <= totalPages; i += 1) { %>
          <a class="rounded-md border border-line px-3 py-2 text-sm font-bold <%= i === page ? 'bg-ink text-white' : 'bg-white text-ink' %>" href="/blog?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"><%= i %></a>
        <% } %>
      </nav>
    <% } %>
  </div>
</section>
