<section class="grid min-h-[calc(100vh-4rem)] place-items-center bg-paper py-12">
  <div class="w-full max-w-md px-4">
    <div class="rounded-lg border border-line bg-white p-6 shadow-soft">
      <h1 class="font-display text-3xl font-extrabold">Reset access</h1>
      <p class="mt-3 text-sm leading-6 text-ink/70">Enter the admin email address to generate a secure reset link.</p>
      <% if (errors.length) { %>
        <div class="mt-5 rounded-md border border-flame/20 bg-flame/10 p-3 text-sm font-medium text-flame">
          <% errors.forEach((error) => { %><p><%= error %></p><% }) %>
        </div>
      <% } %>
      <form action="/admin/forgot-password" method="post" class="mt-6 grid gap-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="grid gap-2 text-sm font-semibold">Email
          <input class="focus-ring min-h-11 rounded-md border border-line px-3 text-base font-normal" name="email" type="email" autocomplete="email" required>
        </label>
        <button class="btn-primary w-full" type="submit">Request Reset</button>
      </form>
      <a class="mt-5 inline-flex text-sm font-bold text-flame hover:text-ink" href="/admin/login">Back to login</a>
    </div>
  </div>
</section>
