<section class="grid min-h-[calc(100vh-4rem)] place-items-center bg-paper py-12">
  <div class="w-full max-w-md px-4">
    <div class="rounded-lg border border-line bg-white p-6 shadow-soft">
      <h1 class="font-display text-3xl font-extrabold">Choose new password</h1>
      <p class="mt-3 text-sm leading-6 text-ink/70">Use at least 12 characters with uppercase, lowercase, and a number.</p>
      <% if (errors.length) { %>
        <div class="mt-5 rounded-md border border-flame/20 bg-flame/10 p-3 text-sm font-medium text-flame">
          <% errors.forEach((error) => { %><p><%= error %></p><% }) %>
        </div>
      <% } %>
      <form action="/admin/reset-password/<%= token %>" method="post" class="mt-6 grid gap-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="grid gap-2 text-sm font-semibold">Password
          <input class="focus-ring min-h-11 rounded-md border border-line px-3 text-base font-normal" name="password" type="password" autocomplete="new-password" required minlength="12">
        </label>
        <label class="grid gap-2 text-sm font-semibold">Confirm password
          <input class="focus-ring min-h-11 rounded-md border border-line px-3 text-base font-normal" name="confirmPassword" type="password" autocomplete="new-password" required minlength="12">
        </label>
        <button class="btn-primary w-full" type="submit">Update Password</button>
      </form>
    </div>
  </div>
</section>
