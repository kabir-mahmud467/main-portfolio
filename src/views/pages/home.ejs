<section class="relative overflow-hidden border-b border-line bg-ink text-white">
  <div class="container-page grid min-h-[calc(100vh-4rem)] items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:py-20">
    <div class="animate-rise">
      <p class="text-sm font-bold uppercase tracking-wider text-flame">kabirmahmud.xyz</p>
      <h1 class="mt-5 max-w-4xl font-display text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">
        Software architecture, developer tools, and technical content that scale.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/70">
        A premium personal platform for full-stack engineering, portfolio proof, practical writing, and fast browser-first utilities.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/projects" class="focus-ring inline-flex min-h-11 items-center justify-center rounded-md bg-white px-5 py-3 text-sm font-bold text-ink transition hover:bg-paper">View Projects</a>
        <a href="/tools" class="focus-ring inline-flex min-h-11 items-center justify-center rounded-md border border-white/15 px-5 py-3 text-sm font-bold text-white transition hover:bg-white/10">Explore Tools</a>
      </div>
    </div>

    <div class="animate-rise min-w-0 rounded-lg border border-white/10 bg-white/5 p-4 shadow-soft backdrop-blur">
      <div class="rounded-md border border-white/10 bg-[#0f1720] p-4">
        <div class="flex gap-2">
          <span class="h-3 w-3 rounded-full bg-flame"></span>
          <span class="h-3 w-3 rounded-full bg-[#d4a017]"></span>
          <span class="h-3 w-3 rounded-full bg-moss"></span>
        </div>
        <pre class="mt-5 overflow-x-auto">
<code class="block whitespace-pre text-xs sm:text-sm leading-6 text-white/75">const engineer = {
  stack: ["React", "Vite", "Node.js", "Express", "MongoDB"],
  environments: ["Linux/Kali/Debian", "Vercel"],
  focus: "Full-Stack Applications & Interactive UI",
  modules: ["3D Graphics", "Branching Engines", "SEO Utilities"],
  posture: "Secure, performant, clean architecture"
};</code></pre>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-3">
        <% statistics.forEach((item) => { %>
          <div class="rounded-md border border-white/10 bg-white/5 p-4">
            <p class="text-2xl font-extrabold"><%= item.value %></p>
            <p class="mt-1 text-xs font-bold uppercase tracking-wider text-white/50"><%= item.label %></p>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<!-- About Section with Image on Top -->
<section class="bg-white py-16">
  <div class="container-page grid gap-10 items-start lg:grid-cols-[0.8fr_1.2fr]">
    <!-- Image block structured to sit cleanly on top -->
    <div class="flex justify-center lg:justify-start order-first">
      <div class="h-32 w-32 shrink-0 rounded-full border border-line bg-paper p-1 shadow-sm sm:h-40 sm:w-40 lg:h-44 lg:w-44">
        <div class="h-full w-full overflow-hidden rounded-full border border-dashed border-ink/10 bg-ink/5">
          <img 
            src="/images/image.jpg" 
            alt="Kabir Mahmud" 
            class="h-full w-full max-h-full max-w-full object-cover rounded-full"
            loading="eager"
          />
        </div>
      </div>
    </div>
    
    <!-- About Text Content -->
    <div class="lg:mt-2">
      <p class="text-sm font-bold uppercase tracking-wider text-ocean">About</p>
      <h2 class="mt-3 font-display text-3xl font-extrabold">A developer brand built around useful systems.</h2>
      <p class="mt-6 text-lg leading-8 text-ink/70">
        Kabir Mahmud focuses on production-ready web platforms: clean client-side React architectures, practical back-end workflows, structural digital publishing, SEO strategy, and interactive interfaces enhanced with structural creative code libraries.
      </p>
    </div>
  </div>
</section>

<!-- Documents & Certifications Section -->
<section class="border-t border-line bg-white py-16">
  <div class="container-page">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-wider text-moss">Verification</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold">Documents & Certifications</h2>
      </div>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <article class="rounded-lg border border-line bg-paper p-5 transition hover:-translate-y-0.5 hover:bg-white hover:shadow-soft">
        <div class="flex items-center gap-3 text-flame">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
          <span class="text-xs font-bold uppercase tracking-wider text-ink/50">Verification Document</span>
        </div>
        <h3 class="mt-3 text-lg font-extrabold">Academic Transcripts & Board Materials</h3>
        <p class="mt-2 text-sm leading-6 text-ink/70">Verified structural certifications, formal educational tracking references, and administrative evaluations.</p>
      </article>

      <article class="rounded-lg border border-line bg-paper p-5 transition hover:-translate-y-0.5 hover:bg-white hover:shadow-soft">
        <div class="flex items-center gap-3 text-ocean">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
          </svg>
          <span class="text-xs font-bold uppercase tracking-wider text-ink/50">Technical Credential</span>
        </div>
        <h3 class="mt-3 text-lg font-extrabold">Full-Stack Development Certifications</h3>
        <p class="mt-2 text-sm leading-6 text-ink/70">Verified completion proofs for production application designs, data structures, and back-end integration models.</p>
      </article>

      <article class="rounded-lg border border-line bg-paper p-5 transition hover:-translate-y-0.5 hover:bg-white hover:shadow-soft">
        <div class="flex items-center gap-3 text-moss">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A8.915 8.915 0 0 1 3 12c0-.778.099-1.533.284-2.253" />
          </svg>
          <span class="text-xs font-bold uppercase tracking-wider text-ink/50">Global Engagement</span>
        </div>
        <h3 class="mt-3 text-lg font-extrabold">International Diplomacy Simulations</h3>
        <p class="mt-2 text-sm leading-6 text-ink/70">Credential documentation confirming entry and evaluation in global leadership forums and communication frameworks.</p>
      </article>
    </div>
  </div>
</section>

<section class="border-t border-line bg-paper py-16">
  <div class="container-page">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-wider text-flame">Skills</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold">Capabilities</h2>
      </div>
      <a href="/contact" class="btn-secondary">Work Together</a>
    </div>
    <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <% skills.forEach((skill) => { %>
        <div class="rounded-lg border border-line bg-white p-4 text-sm font-bold shadow-sm"><%= skill %></div>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-white py-16">
  <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <p class="text-sm font-bold uppercase tracking-wider text-moss">Experience</p>
      <h2 class="mt-3 font-display text-3xl font-extrabold">Architecture-minded execution.</h2>
    </div>
    <div class="grid gap-4">
      <% experience.forEach((item) => { %>
        <article class="rounded-lg border border-line bg-paper p-5">
          <h3 class="text-lg font-extrabold"><%= item.role %></h3>
          <p class="mt-2 text-sm leading-6 text-ink/70"><%= item.detail %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-ink py-16 text-white">
  <div class="container-page">
    <p class="text-sm font-bold uppercase tracking-wider text-flame">Tech Stack</p>
    <h2 class="mt-3 font-display text-3xl font-extrabold">Modern, durable, and intentionally lightweight.</h2>
    <div class="mt-8 flex flex-wrap gap-3">
      <% techStack.forEach((tech) => { %>
        <span class="rounded-md border border-white/10 bg-white/5 px-4 py-2 text-sm font-bold text-white/80"><%= tech %></span>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-paper py-16">
  <div class="container-page">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-wider text-ocean">Featured Projects</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold">Selected builds and platform areas.</h2>
      </div>
      <a href="/projects" class="btn-secondary">All Projects</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      <% featuredProjects.forEach((project) => { %>
        <article class="rounded-lg border border-line bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-soft">
          <h3 class="text-xl font-extrabold"><a href="<%= project.href %>"><%= project.title %></a></h3>
          <p class="mt-3 text-sm leading-6 text-ink/70"><%= project.summary %></p>
          <div class="mt-5 flex flex-wrap gap-2">
            <% project.stack.slice(0, 4).forEach((tech) => { %>
              <span class="rounded-md border border-line bg-paper px-2.5 py-1 text-xs font-bold text-ink/65"><%= tech %></span>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-white py-16">
  <div class="container-page">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-wider text-flame">Featured Tools</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold">Fast utilities with their own SEO pages.</h2>
      </div>
      <a href="/tools" class="btn-secondary">All Tools</a>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% featuredTools.forEach((tool) => { %>
        <a class="rounded-lg border border-line bg-paper p-5 transition hover:-translate-y-0.5 hover:bg-white hover:shadow-soft" href="<%= tool.route %>">
          <p class="text-xs font-bold uppercase tracking-wider text-ocean"><%= tool.category %></p>
          <h3 class="mt-3 text-lg font-extrabold"><%= tool.name %></h3>
          <p class="mt-2 text-sm leading-6 text-ink/70"><%= tool.description %></p>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<section class="border-y border-line bg-paper py-16">
  <div class="container-page">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-wider text-moss">Latest Blog Posts</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold">Technical writing and notes.</h2>
      </div>
      <a href="/blog" class="btn-secondary">Read Blog</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      <% if (!latestPosts.length) { %>
        <article class="rounded-lg border border-line bg-white p-5 md:col-span-3">
          <h3 class="text-xl font-extrabold">Publishing system ready</h3>
          <p class="mt-2 text-sm leading-6 text-ink/70">Latest published posts will appear here automatically.</p>
        </article>
      <% } %>
      <% latestPosts.forEach((post) => { %>
        <article class="rounded-lg border border-line bg-white p-5 shadow-sm">
          <p class="text-xs font-bold uppercase tracking-wider text-ink/50"><%= post.readingTime %> min read</p>
          <h3 class="mt-3 text-xl font-extrabold"><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
          <p class="mt-3 text-sm leading-6 text-ink/70"><%= post.excerpt %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-white py-16">
  <div class="container-page grid gap-5 md:grid-cols-2">
    <% testimonials.forEach((item) => { %>
      <figure class="rounded-lg border border-line bg-paper p-6">
        <blockquote class="text-lg font-semibold leading-8">“<%= item.quote %>”</blockquote>
        <figcaption class="mt-4 text-sm font-bold text-ink/60"><%= item.name %></figcaption>
      </figure>
    <% }) %>
  </div>
</section>

<section class="bg-ink py-16 text-white">
  <div class="container-page grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-wider text-flame">Newsletter</p>
      <h2 class="mt-3 font-display text-3xl font-extrabold">Get engineering notes and platform updates.</h2>
      <p class="mt-3 text-sm leading-6 text-white/65">A minimal subscription surface ready to connect to your future email provider.</p>
    </div>
    <form action="/contact" method="get" class="grid gap-3 sm:grid-cols-[1fr_auto]">
      <input class="focus-ring min-h-12 rounded-md border border-white/10 bg-white px-3 text-ink" type="email" placeholder="you@example.com" aria-label="Email address">
      <button class="focus-ring inline-flex min-h-12 items-center justify-center rounded-md bg-white px-5 text-sm font-bold text-ink hover:bg-paper" type="submit">Join List</button>
    </form>
  </div>
</section>

<section class="bg-paper py-16">
  <div class="container-page rounded-lg border border-line bg-white p-6 shadow-sm sm:p-8">
    <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-wider text-flame">Contact</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold">Have a serious web platform to build?</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-ink/70">Start a conversation about architecture, admin systems, publishing platforms, developer tools, or performance-focused full-stack work.</p>
      </div>
      <a href="/contact" class="btn-primary">Contact Kabir</a>
    </div>
  </div>
</section>