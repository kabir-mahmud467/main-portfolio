<%- include("../../partials/tool-shell") %>
<section class="bg-paper py-12"><div class="container-page max-w-3xl"><form id="password-tool" class="grid gap-4 rounded-lg border border-line bg-white p-5"><input id="password-length" class="focus-ring min-h-11 rounded-md border border-line px-3" type="number" min="8" max="128" value="20"><div class="grid gap-3 sm:grid-cols-4"><label><input id="password-lower" type="checkbox" checked> Lower</label><label><input id="password-upper" type="checkbox" checked> Upper</label><label><input id="password-number" type="checkbox" checked> Numbers</label><label><input id="password-symbol" type="checkbox" checked> Symbols</label></div><button class="btn-primary" type="submit">Generate</button><textarea id="tool-output" class="min-h-24 rounded-md border border-line p-3 font-mono"></textarea><button data-copy-output class="btn-secondary" type="button">Copy</button></form></div></section><script src="/js/tools.js" defer></script>
