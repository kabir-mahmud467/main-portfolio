<%- include("../../partials/tool-shell") %>
<section class="bg-paper py-12"><div class="container-page max-w-3xl"><form id="image-tool" class="grid gap-4 rounded-lg border border-line bg-white p-5"><input id="image-input" type="file" accept="image/*"><input id="image-quality" type="range" min="0.1" max="1" step="0.05" value="0.7"><input id="image-format" type="hidden" value="image/jpeg"><button class="btn-primary" type="submit">Compress Image</button><a id="image-output" class="btn-secondary hidden" download="compressed.jpg">Download Result</a></form></div></section><script src="/js/tools.js" defer></script>
