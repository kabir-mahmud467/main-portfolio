<%- include("../../partials/tool-shell") %>
<section class="bg-paper py-12"><div class="container-page max-w-3xl"><form id="image-tool" class="grid gap-4 rounded-lg border border-line bg-white p-5"><input id="image-input" type="file" accept="image/*"><select id="image-format" class="focus-ring min-h-11 rounded-md border border-line px-3"><option value="image/png">PNG</option><option value="image/jpeg">JPEG</option><option value="image/webp">WebP</option></select><input id="image-quality" type="hidden" value="0.9"><button class="btn-primary" type="submit">Convert Image</button><a id="image-output" class="btn-secondary hidden" download="converted-image">Download Result</a></form></div></section><script src="/js/tools.js" defer></script>
