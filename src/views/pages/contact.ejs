<section class="border-b border-line bg-white py-16 sm:py-20">
  <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
    <div>
      <p class="text-sm font-bold uppercase tracking-wider text-flame">Contact</p>
      <h1 class="mt-4 font-display text-4xl font-extrabold leading-tight sm:text-5xl">
        Let’s talk about the platform you want to build.
      </h1>
      <p class="mt-6 text-lg leading-8 text-ink/70">
        Send a message about architecture, full-stack engineering, content systems, or collaboration.
      </p>
    </div>

    <form action="/contact" method="post" class="rounded-lg border border-line bg-paper p-5 shadow-soft sm:p-6">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="grid gap-2 text-sm font-semibold">
          Name
          <input class="focus-ring min-h-11 rounded-md border border-line bg-white px-3 text-base font-normal" name="name" type="text" autocomplete="name" required minlength="2" maxlength="120">
        </label>
        <label class="grid gap-2 text-sm font-semibold">
          Email
          <input class="focus-ring min-h-11 rounded-md border border-line bg-white px-3 text-base font-normal" name="email" type="email" autocomplete="email" required>
        </label>
      </div>
      <label class="mt-5 grid gap-2 text-sm font-semibold">
        Subject
        <input class="focus-ring min-h-11 rounded-md border border-line bg-white px-3 text-base font-normal" name="subject" type="text" required minlength="3" maxlength="180">
      </label>
      <label class="mt-5 grid gap-2 text-sm font-semibold">
        Message
        <textarea class="focus-ring min-h-40 rounded-md border border-line bg-white px-3 py-3 text-base font-normal leading-6" name="message" required minlength="10" maxlength="5000"></textarea>
      </label>
      <button class="btn-primary mt-6 w-full sm:w-auto" type="submit">Send Message</button>
    </form>
  </div>
</section>

<section class="bg-paper py-16">
  <div class="container-page grid gap-4 md:grid-cols-3">
    <div class="rounded-lg border border-line bg-white p-5">
      <h2 class="font-bold">Architecture</h2>
      <p class="mt-2 text-sm leading-6 text-ink/70">System design, backend structure, scaling paths, and production hardening.</p>
    </div>
    <div class="rounded-lg border border-line bg-white p-5">
      <h2 class="font-bold">Full-stack builds</h2>
      <p class="mt-2 text-sm leading-6 text-ink/70">Express applications, admin dashboards, content systems, and frontend experiences.</p>
    </div>
    <div class="rounded-lg border border-line bg-white p-5">
      <h2 class="font-bold">Technical content</h2>
      <p class="mt-2 text-sm leading-6 text-ink/70">Developer-focused writing, project storytelling, SEO structure, and documentation.</p>
    </div>
  </div>
</section>
